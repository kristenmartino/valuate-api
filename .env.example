# valuate-api environment variables.
# Copy to .env (gitignored) for local dev, or set in the Railway project UI.

# Required by SEC EDGAR — they rate-limit/block requests without a UA string.
# Format: "Your Name your.email@domain.com"
SEC_USER_AGENT="Your Name your.email@example.com"

# Required for Track B (Claude HTML extraction). Get one at:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."

# Optional. When set, extracted Companies and HITL overrides persist via
# Postgres and survive Railway redeploys. Without it the server falls back
# to in-memory storage. On Railway, add the Postgres plugin and DATABASE_URL
# is injected automatically.
# DATABASE_URL="postgres://user:pass@host:5432/db"

# Optional. Bearer token required on PUT /company/{ticker}/override. When set,
# the endpoint returns 401 without `Authorization: Bearer <token>`. The frontend's
# proxy.ts injects this from its own server-side env var of the same name.
# When unset, /override runs unauthenticated (fine for local dev).
# VALUATE_OVERRIDE_TOKEN="generate-with-openssl-rand-hex-32"

# Optional. Rate limit on POST /extract — "<count>/<window-seconds>".
# Default 10 extracts/hour/IP. The endpoint is the expensive one (Claude
# calls); read endpoints (/value, /comps, /company) aren't limited.
# VALUATE_EXTRACT_RATE_LIMIT="10/3600"
